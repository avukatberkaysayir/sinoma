default_platform(:android)

platform :android do
  # ── Internal track (smoke-test release before wider rollout) ──────────────
  lane :internal do |options|
    version_name = options[:version_name] || "1.0.0"
    version_code = options[:version_code] || "1"

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "flutter.versionName" => version_name,
        "flutter.versionCode" => version_code,
      }
    )

    upload_to_play_store(
      track: "internal",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  # ── Production rollout ─────────────────────────────────────────────────────
  lane :production do |options|
    version_name = options[:version_name] || "1.0.0"
    version_code = options[:version_code] || "1"

    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: "android/",
      properties: {
        "flutter.versionName" => version_name,
        "flutter.versionCode" => version_code,
      }
    )

    upload_to_play_store(
      track: "production",
      rollout: "0.1",    # 10 % staged rollout — increase via Play Console
      aab: "build/app/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
    )
  end
end
