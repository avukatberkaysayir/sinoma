rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function doesNotWriteCredits() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['aiCredits']);
    }

    // Users: owner can read/write their own doc, but never write aiCredits directly.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && doesNotWriteCredits();
    }

    // Dictionary and videos: any authenticated user can read. No client writes.
    match /dictionary/{wordId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /videos/{videoId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Posts: authenticated users can read. Owner can create/update/delete.
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.authorId);
    }

    // Leaderboard: read-only for authenticated users (written by Cloud Functions only).
    match /leaderboard/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
